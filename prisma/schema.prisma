generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  KITCHEN_STAFF
  WAITER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum KitchenType {
  MAIN
  TIME_TAKING
  READY_TO_SERVE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Restaurant {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  logoUrl     String?
  bannerUrl   String?
  address     Json?
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(255)
  timezone    String   @default("Asia/Kolkata") @db.VarChar(50)
  currency    String   @default("INR") @db.VarChar(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[]
  orders     Order[]
  users      User[]
  settings   RestaurantSettings?

  // Perf: analytics job queries isActive frequently across all restaurants
  @@index([isActive])
  @@map("restaurants")
}

/// Per-restaurant customisation & financial settings.
/// Created automatically on restaurant registration; always has exactly one row per restaurant.
model RestaurantSettings {
  id           String   @id @default(cuid())
  restaurantId String   @unique

  // ── Financial ──────────────────────────────────────────────────────────────
  /// Tax rate as a decimal fraction, e.g. 0.05 = 5 %.
  /// Falls back to 0.05 when null for backward-compatibility.
  taxRate         Decimal  @default(0.05) @db.Decimal(6, 4)
  /// Service/platform charge as a decimal fraction, e.g. 0.02 = 2 %.
  serviceCharge   Decimal  @default(0.00) @db.Decimal(6, 4)

  // ── Branding ───────────────────────────────────────────────────────────────
  primaryColor    String?  @db.VarChar(20)
  secondaryColor  String?  @db.VarChar(20)
  accentColor     String?  @db.VarChar(20)
  fontHeading     String?  @db.VarChar(100)
  fontBody        String?  @db.VarChar(100)
  /// Raw CSS injected into the public menu page (sanitised at write time).
  customCss       String?  @db.Text

  // ── Operations ─────────────────────────────────────────────────────────────
  /// JSON array of { day: 0-6, open: "HH:MM", close: "HH:MM", closed: bool }
  openingHours    Json?
  /// When true the menu page shows an "ordering unavailable" banner.
  offlineMode     Boolean  @default(false)
  
  autoAcceptOrders   Boolean  @default(false)
  estimatedPrepMins  Int      @default(20)
  offlineModeMessage String?  @db.VarChar(500)
  serviceChargeLabel String?  @db.VarChar(100)
  notifyOnNewOrder   Boolean  @default(true)
  notifyOnLowStock   Boolean  @default(false)
  notifyEmail        String?  @db.VarChar(255)
  
  showCalories       Boolean  @default(true)
  showPrepTime       Boolean  @default(true)
  showVegBadge       Boolean  @default(true)
  menuLayout         String   @default("grid") @db.VarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_settings")
}

model User {
  id           String    @id @default(cuid())
  restaurantId String?
  email        String    @unique @db.VarChar(255)
  passwordHash String
  firstName    String    @db.VarChar(50)
  lastName     String    @db.VarChar(50)
  phone        String?   @db.VarChar(20)
  role         UserRole  @default(KITCHEN_STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  sessions   Session[]

  @@index([restaurantId])
  // Perf: staff listing filters by restaurantId + role simultaneously
  @@index([restaurantId, role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id           String   @id @default(cuid())
  restaurantId String
  name         String   @db.VarChar(100)
  description  String?  @db.VarChar(500)
  imageUrl     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  // Perf: public menu query filters (restaurantId, isActive) and sorts by sortOrder
  // Composite covers all three in a single index scan
  @@index([restaurantId, isActive, sortOrder])
  // Kept for backward-compat with any non-isActive admin queries
  @@index([restaurantId, sortOrder])
  @@map("categories")
}

model MenuItem {
  id           String      @id @default(cuid())
  categoryId   String
  name         String      @db.VarChar(150)
  description  String?     @db.VarChar(1000)
  price        Decimal     @db.Decimal(10, 2)
  imageUrl     String?
  kitchenType  KitchenType @default(MAIN)
  isAvailable  Boolean     @default(true)
  isPopular    Boolean     @default(false)
  isVeg        Boolean     @default(true)
  calories     Int?
  prepTimeMins Int         @default(15)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  // Perf: public menu filters isAvailable and sorts by sortOrder within a category
  // Replaces the separate [categoryId, sortOrder] and [isAvailable] indexes with
  // one composite that serves all three query shapes
  @@index([categoryId, isAvailable, sortOrder])
  @@map("menu_items")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @db.VarChar(30)
  restaurantId    String
  status          OrderStatus @default(PENDING)
  orderType       OrderType   @default(DINE_IN)
  tableNumber     String?     @db.VarChar(20)
  customerName    String?     @db.VarChar(100)
  customerPhone   String?     @db.VarChar(20)
  customerEmail   String?     @db.VarChar(255)
  notes           String?     @db.VarChar(1000)
  deliveryAddress String?     @db.VarChar(500)
  subtotal        Decimal     @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  estimatedMins   Int         @default(20)
  confirmedAt     DateTime?
  preparedAt      DateTime?
  readyAt         DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  // Perf: kitchen queue and admin list filter by (restaurantId, status)
  @@index([restaurantId, status])
  // Perf: admin list sorts/filters by createdAt within a restaurant
  @@index([restaurantId, createdAt])
  // Perf: analytics queries filter by (restaurantId, status, createdAt) together
  // — covers COUNT, SUM, and findMany with all three predicates in a single scan
  @@index([restaurantId, status, createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  name       String  @db.VarChar(150)
  price      Decimal @db.Decimal(10, 2)
  quantity   Int
  subtotal   Decimal @db.Decimal(10, 2)
  notes      String? @db.VarChar(500)

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  // Perf: analytics groupBy(['menuItemId', 'name']) needs this to avoid seq-scan
  @@index([menuItemId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?     @db.VarChar(500)
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model DailyAnalytics {
  id              String   @id @default(cuid())
  restaurantId    String
  date            DateTime @db.Date
  totalOrders     Int      @default(0)
  completedOrders Int      @default(0)
  cancelledOrders Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  avgPrepTimeMins Decimal  @default(0) @db.Decimal(6, 2)
  peakHour        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([restaurantId, date])
  @@index([restaurantId, date])
  @@map("daily_analytics")
}
